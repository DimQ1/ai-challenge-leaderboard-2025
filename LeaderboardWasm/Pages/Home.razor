@page "/"

<PageTitle>Leaderboard</PageTitle>

<div class="page-scaffold">
	<div class="leaderboard-shell">
		<header class="leaderboard-header">
			<h1>Leaderboard</h1>
			<p>Top performers based on contributions and activity</p>
		</header>

		@if (!string.IsNullOrWhiteSpace(ErrorMessage))
		{
			<div class="status-card error">@ErrorMessage</div>
		}
		else if (IsLoading)
		{
			<div class="status-card">Loading leaderboard...</div>
		}
		else
		{
			<section class="filters-panel">
				<select class="select-input" @bind="SelectedYear">
					<option value="all">All Years</option>
					@foreach (var year in AllYears)
					{
						<option value="@year.ToString()">@year</option>
					}
				</select>

				<select class="select-input" @bind="SelectedQuarter">
					<option value="all">All Quarters</option>
					@foreach (var quarter in AllQuarters)
					{
						<option value="@quarter">@quarter</option>
					}
				</select>

				<select class="select-input" @bind="SelectedCategory">
					<option value="all">All Categories</option>
					@foreach (var category in AllCategories)
					{
						<option value="@category">@category</option>
					}
				</select>

				<div class="search-input-wrap">
					<span class="search-glyph" aria-hidden="true">⌕</span>
					<input
						class="text-input"
						type="search"
						placeholder="Search employee..."
						@bind="SearchQuery"
						@bind:event="oninput" />
				</div>
			</section>

			@if (FilteredLeaderboard.Count == 0)
			{
				<div class="status-card">No activities found matching the current filters.</div>
			}
			else
			{
				var first = GetTopAt(0);
				var second = GetTopAt(1);
				var third = GetTopAt(2);

				<section class="podium-panel">
					<div class="podium-people">
						@if (second is not null)
						{
							<article class="podium-person place-2">
								<img class="profile-photo podium-photo" src="@second.PhotoUrl" alt="Profile illustration" />
								<span class="medal med-2">2</span>
								<h2>@second.Name</h2>
								<p>@second.Title</p>
								<div class="podium-points"><span class="star">★</span> @second.TotalPoints</div>
							</article>
						}

						@if (first is not null)
						{
							<article class="podium-person place-1">
								<img class="profile-photo podium-photo" src="@first.PhotoUrl" alt="Profile illustration" />
								<span class="medal med-1">1</span>
								<h2>@first.Name</h2>
								<p>@first.Title</p>
								<div class="podium-points"><span class="star">★</span> @first.TotalPoints</div>
							</article>
						}

						@if (third is not null)
						{
							<article class="podium-person place-3">
								<img class="profile-photo podium-photo" src="@third.PhotoUrl" alt="Profile illustration" />
								<span class="medal med-3">3</span>
								<h2>@third.Name</h2>
								<p>@third.Title</p>
								<div class="podium-points"><span class="star">★</span> @third.TotalPoints</div>
							</article>
						}
					</div>

					<div class="podium-steps">
						<div class="step second">2</div>
						<div class="step first">1</div>
						<div class="step third">3</div>
					</div>
				</section>

				<section class="list-panel">
					@foreach (var entry in FilteredLeaderboard)
					{
						<article class="person-row @(ExpandedPeople.Contains(entry.PersonId) ? "expanded" : string.Empty)">
							<div class="person-main">
								<div class="rank-col">@entry.Rank</div>
								<img class="profile-photo row-photo" src="@entry.PhotoUrl" alt="Profile illustration" />
								<div class="person-meta">
									<h3>@entry.Name</h3>
									<p>@entry.Title</p>
								</div>

								<div class="mini-stats">
									<div class="mini-stat">
										<span class="mini-icon">◫</span>
										<span>@entry.ActivityCount</span>
									</div>
								</div>

								<div class="points-block">
									<div class="points-label">TOTAL</div>
									<div class="points-value">★ @entry.TotalPoints</div>
								</div>

								<button class="toggle-button" type="button" aria-label="Toggle details" @onclick="() => ToggleExpanded(entry.PersonId)">
									@(ExpandedPeople.Contains(entry.PersonId) ? "⌃" : "⌄")
								</button>
							</div>

							@if (ExpandedPeople.Contains(entry.PersonId))
							{
								<div class="activities-wrap">
									<h4>RECENT ACTIVITY</h4>
									<table>
										<thead>
											<tr>
												<th>ACTIVITY</th>
												<th>CATEGORY</th>
												<th>DATE</th>
												<th class="align-right">POINTS</th>
											</tr>
										</thead>
										<tbody>
											@foreach (var activity in entry.Activities)
											{
												<tr>
													<td>@activity.ActivityName</td>
													<td><span class="category-chip">@activity.Category</span></td>
													<td>@activity.ActivityDate.ToString("dd-MMM-yyyy")</td>
													<td class="align-right">+@activity.Points</td>
												</tr>
											}
										</tbody>
									</table>
								</div>
							}
						</article>
					}
				</section>
			}
		}
	</div>
</div>

@code {
	private readonly List<ActivityItem> RawActivities = BuildSyntheticActivities();
	private readonly HashSet<string> ExpandedPeople = new();
	private string SearchQuery = string.Empty;
	private string SelectedYear = "all";
	private string SelectedQuarter = "all";
	private string SelectedCategory = "all";

	private bool IsLoading = true;
	private string? ErrorMessage;

	private IReadOnlyList<int> AllYears => RawActivities.Select(x => x.Year).Distinct().OrderByDescending(x => x).ToList();

	private IReadOnlyList<string> AllQuarters => RawActivities.Select(x => x.Quarter).Distinct().OrderBy(x => x).ToList();

	private IReadOnlyList<string> AllCategories => RawActivities.Select(x => x.Category).Distinct().OrderBy(x => x).ToList();

	private LeaderboardEntry? GetTopAt(int index)
	{
		return FilteredLeaderboard.Count > index ? FilteredLeaderboard[index] : null;
	}

	private List<LeaderboardEntry> FilteredLeaderboard
	{
		get
		{
			var filtered = RawActivities.AsEnumerable();

			if (SelectedYear != "all" && int.TryParse(SelectedYear, out var year))
			{
				filtered = filtered.Where(x => x.Year == year);
			}

			if (SelectedQuarter != "all")
			{
				filtered = filtered.Where(x => x.Quarter == SelectedQuarter);
			}

			if (SelectedCategory != "all")
			{
				filtered = filtered.Where(x => x.Category == SelectedCategory);
			}

			if (!string.IsNullOrWhiteSpace(SearchQuery))
			{
				filtered = filtered.Where(x => x.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));
			}

			var aggregated = filtered
				.GroupBy(x => new { x.PersonId, x.Name, x.Title, x.PhotoUrl })
				.Select(g => new LeaderboardEntry(
					g.Key.PersonId,
					g.Key.Name,
					g.Key.Title,
					g.Key.PhotoUrl,
					g.Sum(x => x.Points),
					g.Count(x => x.Category == "Public Speaking" || x.Category == "Innovation Challenge"),
					g.Count(x => x.Category == "Education" || x.Category == "Mentor Support"),
					g.OrderByDescending(x => x.ActivityDate).ToList(),
					0))
				.ToList();

			aggregated = aggregated.OrderByDescending(x => x.TotalPoints).ThenBy(x => x.Name).ToList();

			for (var i = 0; i < aggregated.Count; i++)
			{
				aggregated[i] = aggregated[i] with { Rank = i + 1 };
			}

			return aggregated;
		}
	}

	protected override async Task OnInitializedAsync()
	{
		try
		{
			await Task.Delay(350);
		}
		catch
		{
			ErrorMessage = "Error loading leaderboard data";
		}
		finally
		{
			IsLoading = false;
		}
	}

	private void ToggleExpanded(string personId)
	{
		if (!ExpandedPeople.Add(personId))
		{
			ExpandedPeople.Remove(personId);
		}
	}

