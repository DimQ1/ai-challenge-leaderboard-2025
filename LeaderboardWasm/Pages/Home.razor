	private sealed record ActivityItem(
		string PersonId,
		string Name,
		string Title,
		string PhotoUrl,
		string ActivityName,
		string Category,
		DateTime ActivityDate,
		int Points)
	{
		public int Year => ActivityDate.Year;
		public string Quarter => $"Q{((ActivityDate.Month - 1) / 3) + 1}";
	}

	private sealed record LeaderboardEntry(
		string PersonId,
		string Name,
		string Title,
		string PhotoUrl,
		int TotalPoints,
		int ActivityCount,
		int EducationCount,
		List<ActivityItem> Activities,
		int Rank);
