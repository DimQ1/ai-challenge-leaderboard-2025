	private sealed record SortChoice(string Key, string Label);

	private sealed record ActivityItem(
		string PersonId,
		string Name,
		string Title,
		string Category,
		DateTime ActivityDate,
		int Points)
	{
		public int Year => ActivityDate.Year;
		public string Quarter => $"Q{((ActivityDate.Month - 1) / 3) + 1}";
	}

	private sealed record LeaderboardEntry(
		string PersonId,
		string Name,
		string Title,
		int TotalPoints,
		List<ActivityItem> Activities,
		int Rank);
